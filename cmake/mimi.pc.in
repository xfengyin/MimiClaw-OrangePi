prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=@CMAKE_INSTALL_PREFIX@
libdir=@LIB_INSTALL_DIR@
includedir=@CMAKE_INSTALL_PREFIX@/include

Name: mimi
Description: MimiClaw AI Assistant Library
Version: @PROJECT_VERSION@
Requires: sqlite3 curl openssl
Libs: -L${libdir} -lmimi-core -lmimi-memory -lmimi-config -lmimi-tools
Cflags: -I${includedir}/mimi/core -I${includedir}/mimi/memory -I${includedir}/mimi/config -I${includedir}/mimi/tools