# MimiClaw Environment Configuration
# Copy this file to .env and fill in your values

# OpenAI API Key (required)
MIMI_API_KEY=your_openai_api_key_here

# Model to use (optional, default: gpt-3.5-turbo)
MIMI_MODEL=gpt-3.5-turbo

# Telegram Bot Token (optional)
# Get from @BotFather on Telegram
MIMI_TELEGRAM_BOT_TOKEN=

# Gateway Configuration
MIMI_BIND_ADDR=0.0.0.0
MIMI_PORT=8080
MIMI_WS_PORT=8081
MIMI_MAX_SESSIONS=100